rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /gebruikers/{uid} {

      // User can read their own root document
      allow read: if request.auth != null && request.auth.uid == uid;

      // User can write their root document BUT NOT the 'pakket' field
      // 'pakket' is authoritative from RevenueCat only — never trust the client
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && !('pakket' in request.resource.data);

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !('pakket' in request.resource.data);

      // All subcollections: authenticated owner only
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
